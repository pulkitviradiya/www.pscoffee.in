{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/journal/why-specialty-coffee-costs-300-rupees-india",
      "destination": "/blog/why-specialty-coffee-costs-300-rupees-india",
      "permanent": true
    },
    {
      "source": "/journal/why-specialty-coffee-costs-300-rupees-india.html",
      "destination": "/blog/why-specialty-coffee-costs-300-rupees-india",
      "permanent": true
    },
    {
      "source": "/journal/why-we-built-pods-not-cafes",
      "destination": "/blog/why-we-built-pods-not-cafes",
      "permanent": true
    },
    {
      "source": "/journal/why-we-built-pods-not-cafes.html",
      "destination": "/blog/why-we-built-pods-not-cafes",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
